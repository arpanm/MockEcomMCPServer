              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": {{mcpId}},\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"getPaymentStatus\",\n    \"arguments\": {\n      \"paymentId\": \"{{paymentId}}\",\n      \"sessionId\": \"{{sessionId}}\"\n    }\n  }\n}"
            }
