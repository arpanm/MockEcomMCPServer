              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": {{mcpId}},\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"getAddresses\",\n    \"arguments\": {\n      \"sessionId\": \"{{sessionId}}\"\n    }\n  }\n}"
            }
          }
        },
        {
          "name": "12. selectAddress",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/mcp/message",
            "description": "Attach a delivery address to a checkout. Use addressId from getAddresses.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": {{mcpId}},\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"selectAddress\",\n    \"arguments\": {\n      \"checkoutId\": \"{{checkoutId}}\",\n      \"addressId\": \"{{addressId}}\",\n      \"sessionId\": \"{{sessionId}}\"\n    }\n  }\n}"
            }
          }
        }
      ]
    },
